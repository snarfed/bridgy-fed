[
  {
    "name": "delete-old",
    "action": {"type": "Delete"},
    "condition": {
      "olderThan": "30d"
    }
  },
  {
    "name": "keep-minimum",
    "action": {"type": "Keep"},
    "mostRecentVersions": {
      "packageNamePrefixes": [
        "app/bounce",
        "app/default",
        "default",
        "frontend",
        "hub",
        "router"
      ],
      "keepCount": 10
    }
  }
]
